{
  "type": "object",
  "properties": {
    "testcase_id": {
      "type": "string",
      "description": "ID тест-кейса в Allure TestOps"
    },
    "name": {
      "type": "string",
      "description": "Имя тест-кейса"
    },
    "description": {
      "type": "string",
      "description": "Описание тест-кейса"
    },
    "precondition": {
      "type": "string",
      "description": "Предусловие тест-кейса"
    },
    "steps": {
      "type": "array",
      "description": "Шаги тест-кейса",
      "items": {
        "type": "object",
        "properties": {
          "step_number": {"type": "integer"},
          "action": {"type": "string"},
          "expected_result": {"type": "string"}
        }
      }
